{
  "name": "ai-notes-md",
  "displayName": "SDD AI Notes",
  "description": "Spec-Driven Development: annotate Markdown files for AI agents.",
  "version": "1.1.0",
  "publisher": "ANDREPEIXOTODACUNHA",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/andpeicunha/ai-notes-md"
  },
  "bugs": {
    "url": "https://github.com/andpeicunha/ai-notes-md/issues"
  },
  "homepage": "https://github.com/andpeicunha/ai-notes-md#readme",
  "keywords": [
    "markdown",
    "ai",
    "notes",
    "annotation",
    "comments"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onCommand:aiNotes.addNote",
    "onCommand:aiNotes.addNoteFromContext",
    "onCommand:aiNotes.addNoteFromCodeLens",
    "onCommand:aiNotes.submitInlineNote",
    "onCommand:aiNotes.discardInlineNote",
    "onCommand:aiNotes.revealNote",
    "onCommand:aiNotes.togglePreview",
    "onCustomEditor:aiNotes.markdownPreview"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiNotes.addNote",
        "title": "%aiNotes.command.addNote.title%",
        "category": "%aiNotes.command.category%"
      },
      {
        "command": "aiNotes.addNoteFromContext",
        "title": "%aiNotes.command.addAiNote.title%"
      },
      {
        "command": "aiNotes.addNoteFromCodeLens",
        "title": "%aiNotes.command.addAiNote.title%"
      },
      {
        "command": "aiNotes.submitInlineNote",
        "title": "%aiNotes.command.saveInlineNote.title%",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "aiNotes.discardInlineNote",
        "title": "%aiNotes.command.discardInlineNote.title%"
      },
      {
        "command": "aiNotes.togglePreview",
        "title": "%aiNotes.command.togglePreview.title%",
        "icon": "$(comment-discussion)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "aiNotes.submitInlineNote",
          "when": "false"
        },
        {
          "command": "aiNotes.discardInlineNote",
          "when": "false"
        }
      ],
      "editor/title": [
        {
          "command": "aiNotes.togglePreview",
          "when": "resourceLangId == markdown && resourceExtname == .md",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "aiNotes.addNoteFromContext",
          "when": "editorTextFocus && editorHasSelection && resourceLangId == markdown && resourceExtname == .md",
          "group": "navigation@10"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "aiNotes.submitInlineNote",
          "group": "inline",
          "when": "commentController == ai-notes-md && commentThreadIsEmpty"
        }
      ],
      "comments/commentThread/title": [
        {
          "command": "aiNotes.discardInlineNote",
          "group": "navigation",
          "when": "commentController == ai-notes-md && commentThreadIsEmpty"
        }
      ]
    },
    "configuration": {
      "title": "%aiNotes.configuration.title%",
      "properties": {
        "aiNotes.resolvedNoteAction": {
          "type": "string",
          "enum": [
            "delete",
            "convert-to-history"
          ],
          "default": "delete",
          "description": "%aiNotes.configuration.resolvedNoteAction.description%",
          "enumDescriptions": [
            "%aiNotes.configuration.resolvedNoteAction.delete%",
            "%aiNotes.configuration.resolvedNoteAction.convertToHistory%"
          ]
        }
      }
    },
    "keybindings": [
      {
        "command": "editor.action.submitComment",
        "key": "ctrl+enter",
        "when": "commentEditorFocused && !commentIsEmpty && commentController == ai-notes-md"
      },
      {
        "command": "editor.action.submitComment",
        "key": "cmd+enter",
        "mac": "cmd+enter",
        "when": "commentEditorFocused && !commentIsEmpty && commentController == ai-notes-md"
      }
    ],
    "customEditors": [
      {
        "viewType": "aiNotes.markdownPreview",
        "displayName": "Markdown Preview with AI Notes",
        "selector": [
          { "filenamePattern": "*.md" }
        ],
        "priority": "option"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "compile:webview": "esbuild media/renderer.js --bundle --outfile=media/renderer.bundle.js --format=iife --target=es2020 --platform=browser",
    "vscode:prepublish": "npm run compile && npm run compile:webview"
  },
  "devDependencies": {
    "@types/node": "^20.14.8",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.5.2"
  },
  "dependencies": {
    "dompurify": "^3.4.12",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.6",
    "marked-highlight": "^2.2.4"
  }
}
